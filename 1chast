#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <windows.h>

#define MAX_ROUTES    10
#define ROUTE_LEN     50
#define LOGIN_LEN     50
#define OTZIV_TEXT    280
#define TRIP_DATE_LEN 24

#define ADMIN_LOGIN     "admin"
#define ADMIN_PASSWORD  "admin123"

const char* FILE_OTZIV  = "otziv.txt";
const char* FILE_USERS  = "users.txt";
const char* FILE_ROUTE  = "route.txt";

typedef struct otziv
{
    char route[ROUTE_LEN];
    char author[LOGIN_LEN];
    char text[OTZIV_TEXT];
    int comfort;
    char trip_date[TRIP_DATE_LEN];
} otziv;

char ROUTES[MAX_ROUTES][ROUTE_LEN];
int route_count = 0;

otziv* OTZIV = NULL;
int otziv_count = 0;
int otziv_capacity = 0;

struct user
{
    char login[LOGIN_LEN];
    char password[LOGIN_LEN];
};

struct user* USERS = NULL;
int user_capacity = 0;
int user_count = 0;

char CURRENT_USER[LOGIN_LEN] = "";

void load_route_from_file(void);
void save_route(void);
void add_route(void);

void load_otziv_from_file(void);
void save_otziv(void);
static int append_otziv(const char* route, const char* author, const char* text,
                        int comfort, const char* trip_date);
static void delete_otziv_at(int index);

void browse_routes_and_reviews(int as_admin);

void user_menu(void);
void create_account(void);
void user_vertification(void);
void load_users_from_file(void);
void save_users_to_file(void);
void admin_menu(void);
